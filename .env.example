# ===== 数据库配置 =====
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=stock_analysis

# ===== 任务配置 =====
DAILY_UPDATE_TIME=20:30
REALTIME_POLL_INTERVAL=3

# ===== 股票池配置 =====
# 可填具体代码，或用 hs300 / zz500 / sz50 表示指数成分股
STOCK_POOL=sz000001,sz000002,sh600519,sh601318,sh600036

# ===== 回测默认参数 =====
INITIAL_CAPITAL=100000
COMMISSION_RATE=0.0003
STAMP_DUTY_RATE=0.001
SLIPPAGE_RATE=0.001
